# Keycloak server base URL (no trailing slash)
KEYCLOAK_BASE_URL=http://localhost:8080

# Realm name
KEYCLOAK_REALM=myrealm

# Client ID (must have Standard Flow enabled in Keycloak)
KEYCLOAK_CLIENT_ID=myclient

# Client secret — leave blank for public clients (PKCE-only)
KEYCLOAK_CLIENT_SECRET=

# Full redirect URI — must exactly match the Valid Redirect URI registered in Keycloak.
# The CLI will start a local server on the port and path derived from this value.
# If set, KEYCLOAK_REDIRECT_PORT is ignored.
KEYCLOAK_REDIRECT_URI=http://localhost:8765/callback

# (Alternative) shorthand when the path is /callback and you only want to change the port.
# Ignored if KEYCLOAK_REDIRECT_URI is set.
# KEYCLOAK_REDIRECT_PORT=8765
